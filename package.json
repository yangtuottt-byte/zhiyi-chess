{
  "name": "ai-chess-coach",
  "version": "1.0.0",
  "description": "AI教练版象棋游戏 - 桌面端单机应用",
  "main": "main-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build:next": "next build",
    "build:electron": "tsc -p tsconfig.main.json",
    "postinstall": "electron-builder install-app-deps",
    "electron:dev": "npm run build:electron && concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "pack": "set CSC_IDENTITY_AUTO_DISCOVERY=false && npm run build:next && npm run build:electron && electron-builder --dir",
    "dist": "set CSC_IDENTITY_AUTO_DISCOVERY=false && npm run build:next && npm run build:electron && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "electron-serve": "^1.3.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.zhiyi.chess",
    "productName": "智弈",
    "forceCodeSigning": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main-dist/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "chess_records.db",
        "to": "chess_records.db"
      },
      {
        "from": "engine",
        "to": "engine"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "智弈"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
