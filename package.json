{
  "name": "ai-chess-coach",
  "version": "1.0.0",
  "description": "AI教练版象棋游戏 - 桌面端单机应用",
  "main": "main-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:main": "tsc -p tsconfig.main.json",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || echo \"[postinstall] electron-rebuild skipped\"",
    "electron:dev": "npm run build:main && concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build:main && next build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ai.chess-coach",
    "productName": "AI象棋教练",
    "files": [
      "main-dist/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "chess_records.db",
        "to": "chess_records.db"
      },
      {
        "from": "engine",
        "to": "engine"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
